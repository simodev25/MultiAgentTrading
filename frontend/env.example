VITE_API_URL=http://localhost:8000/api/v1

# Active la section UI des trades MT5 réels (Dashboard, Connectors, Orders)
VITE_ENABLE_METAAPI_REAL_TRADES_DASHBOARD=false

# Paramètres UI de chargement/affichage des données réelles MetaApi
# VITE_METAAPI_REAL_TRADES_DEFAULT_DAYS accepte:
# - une valeur unique (ex: "14") => valeur par défaut + liste UI standard (0,7,14,30,60,90) où 0 = Aujourd'hui
# - une liste CSV (ex: "0,7,14,30,90") => liste UI explicite, premier élément sélectionné par défaut
VITE_METAAPI_REAL_TRADES_DEFAULT_DAYS=14
VITE_METAAPI_REAL_TRADES_DASHBOARD_LIMIT=8
VITE_METAAPI_REAL_TRADES_TABLE_LIMIT=15
VITE_METAAPI_REAL_TRADES_ORDERS_PAGE_LIMIT=25
# Variable recommandée (utilisée en priorité par le runtime)
VITE_METAAPI_REALTIME_PRICES_POLL_MS=4000
# Alias legacy encore supporté
VITE_METAAPI_REAL_TRADES_REFRESH_MS=150000
