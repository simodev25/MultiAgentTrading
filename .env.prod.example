# =========================
# Production environment
# =========================
# Copy to .env.prod then edit secrets:
# cp .env.prod.example .env.prod

APP_NAME=Multi-Agent Trading Platform
ENV=prod
API_PREFIX=/api/v1
SECRET_KEY=change-me-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# =========================
# Ports exposed on host
# =========================
BACKEND_PORT=8000
FRONTEND_PORT=4173
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# =========================
# PostgreSQL
# =========================
POSTGRES_USER=trading
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=trading_platform
DATABASE_URL=postgresql+psycopg2://trading:change-me-db-password@postgres:5432/trading_platform

# =========================
# Redis / Celery / RabbitMQ
# =========================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_IGNORE_RESULT=true
CELERY_ANALYSIS_QUEUE=analysis
CELERY_BACKTEST_QUEUE=backtests
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true
CELERY_TASK_TRACK_STARTED=true
CELERY_WORKER_QUEUES=analysis,backtests
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=200

# =========================
# Workers tuning (Mac M4 Pro recommended)
# =========================
# M4 Pro 12 cores: keep defaults below.
# M4 Pro 14 cores: set BACKEND_UVICORN_WORKERS=5, CELERY_WORKER_CONCURRENCY=5,
# ORCHESTRATOR_PARALLEL_WORKERS=7 (or run ./scripts/install-prod-docker.sh --tune-m4-pro).
BACKEND_UVICORN_WORKERS=4
CELERY_WORKER_CONCURRENCY=4
ORCHESTRATOR_PARALLEL_WORKERS=6

# =========================
# Time limits
# =========================
CELERY_ANALYSIS_SOFT_TIME_LIMIT_SECONDS=300
CELERY_ANALYSIS_TIME_LIMIT_SECONDS=360
CELERY_BACKTEST_SOFT_TIME_LIMIT_SECONDS=1200
CELERY_BACKTEST_TIME_LIMIT_SECONDS=1500

# =========================
# External providers
# =========================
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_INPUT_COST_PER_1M_TOKENS=0
OLLAMA_OUTPUT_COST_PER_1M_TOKENS=0
LLM_PROVIDER=ollama
DECISION_MODE=conservative
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_INPUT_COST_PER_1M_TOKENS=0
OPENAI_OUTPUT_COST_PER_1M_TOKENS=0
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TIMEOUT_SECONDS=30
MISTRAL_INPUT_COST_PER_1M_TOKENS=0
MISTRAL_OUTPUT_COST_PER_1M_TOKENS=0
AGENT_SKILLS_BOOTSTRAP_FILE=/app/config/agent-skills.json
AGENT_SKILLS_BOOTSTRAP_MODE=merge
AGENT_SKILLS_BOOTSTRAP_APPLY_ONCE=true

METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=
METAAPI_REGION=new-york
METAAPI_BASE_URL=https://mt-client-api-v1.london.agiliumtrade.ai
METAAPI_MARKET_BASE_URL=https://mt-market-data-client-api-v1.london.agiliumtrade.ai
METAAPI_AUTH_HEADER=auth-token
METAAPI_REST_TIMEOUT_SECONDS=30
METAAPI_USE_SDK_FOR_MARKET_DATA=false
METAAPI_CACHE_ENABLED=true
METAAPI_CACHE_CONNECT_TIMEOUT_SECONDS=0.25
METAAPI_SDK_CONNECT_TIMEOUT_SECONDS=6
METAAPI_SDK_SYNC_TIMEOUT_SECONDS=6
METAAPI_SDK_REQUEST_TIMEOUT_SECONDS=8
METAAPI_SDK_CIRCUIT_BREAKER_SECONDS=20
METAAPI_ACCOUNT_INFO_CACHE_TTL_SECONDS=5
METAAPI_MARKET_CANDLES_CACHE_MIN_TTL_SECONDS=2
METAAPI_MARKET_CANDLES_CACHE_MAX_TTL_SECONDS=12
METAAPI_CACHE_LOCK_TTL_SECONDS=3
METAAPI_CACHE_WAIT_TIMEOUT_SECONDS=1.2

YFINANCE_CACHE_ENABLED=true
YFINANCE_CACHE_CONNECT_TIMEOUT_SECONDS=0.25
YFINANCE_SNAPSHOT_CACHE_MIN_TTL_SECONDS=2
YFINANCE_SNAPSHOT_CACHE_MAX_TTL_SECONDS=30
YFINANCE_NEWS_CACHE_TTL_SECONDS=120
NEWS_PROVIDER_CACHE_TTL_SECONDS=900
YFINANCE_HISTORICAL_CACHE_TTL_SECONDS=900
YFINANCE_CACHE_FRAME_MAX_ROWS=5000
YFINANCE_CACHE_LOCK_TTL_SECONDS=3
YFINANCE_CACHE_WAIT_TIMEOUT_SECONDS=1.2
NEWSAPI_API_KEY=
TRADINGECONOMICS_API_KEY=
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
# JSON map, optional. Defaults are embedded in code when empty.
NEWS_PROVIDERS={"yahoo_finance":{"enabled":true,"priority":100,"timeout_ms":4000},"newsapi":{"enabled":true,"priority":90,"timeout_ms":5000,"api_key_env":"NEWSAPI_API_KEY","languages":["en"],"lookback_hours":48},"tradingeconomics":{"enabled":true,"priority":95,"timeout_ms":5000,"api_key_env":"TRADINGECONOMICS_API_KEY","lookback_hours":72,"importance_threshold":2},"finnhub":{"enabled":false,"priority":70,"timeout_ms":4000,"api_key_env":"FINNHUB_API_KEY","lookback_hours":48},"alphavantage":{"enabled":false,"priority":60,"timeout_ms":5000,"api_key_env":"ALPHAVANTAGE_API_KEY","lookback_hours":48}}
# JSON map, optional. Defaults are embedded in code when empty.
NEWS_ANALYSIS={"max_items_total":25,"max_items_per_provider":10,"deduplicate":true,"deduplicate_on":["title","url","published_at"],"minimum_relevance_score":0.35,"treat_no_news_as_no_evidence":true}

ALLOW_LIVE_TRADING=false
ENABLE_PAPER_EXECUTION=true
ENABLE_METAAPI_REAL_TRADES_DASHBOARD=false
DEFAULT_FOREX_PAIRS=EURUSD.pro,GBPUSD.pro,USDJPY.pro,USDCHF.pro,AUDUSD.pro,USDCAD.pro,NZDUSD.pro,EURJPY.pro,GBPJPY.pro,EURGBP.pro
DEFAULT_CRYPTO_PAIRS=ADAUSD,AVAXUSD,BCHUSD,BNBUSD,BTCUSD,DOGEUSD,DOTUSD,ETHUSD,LINKUSD,LTCUSD,MATICUSD,SOLUSD,UNIUSD
DEFAULT_TIMEFRAMES=M5,M15,H1,H4,D1

PROMETHEUS_ENABLED=true
PROMETHEUS_WORKER_PORT=9101
OPEN_TELEMETRY_ENABLED=false
WS_RUN_POLL_SECONDS=2
WS_TRADING_ORDERS_POLL_SECONDS=2
# =========================
# AgentScope pipeline
# =========================
DEBATE_MAX_ROUNDS=3
DEBATE_MIN_ROUNDS=1
AGENTSCOPE_MAX_ITERS=3

LOG_AGENT_STEPS=true
BACKTEST_AGENT_LOG_EVERY=25
BACKTEST_ENABLE_LLM=false
BACKTEST_LLM_EVERY=24
DEBUG_TRADE_JSON_ENABLED=false
DEBUG_TRADE_JSON_DIR=./debug-traces
DEBUG_TRADE_JSON_INCLUDE_PROMPTS=true
DEBUG_TRADE_JSON_INCLUDE_PRICE_HISTORY=true
DEBUG_TRADE_JSON_PRICE_HISTORY_LIMIT=200
DEBUG_TRADE_JSON_INLINE_IN_RUN_TRACE=false

# =========================
# Frontend build/runtime
# =========================
VITE_API_URL=http://localhost:8000/api/v1
VITE_ENABLE_METAAPI_REAL_TRADES_DASHBOARD=false
VITE_METAAPI_REAL_TRADES_DEFAULT_DAYS=14
VITE_METAAPI_REAL_TRADES_DASHBOARD_LIMIT=8
VITE_METAAPI_REAL_TRADES_TABLE_LIMIT=15
VITE_METAAPI_REAL_TRADES_ORDERS_PAGE_LIMIT=25
VITE_METAAPI_REALTIME_PRICES_POLL_MS=4000

# =========================
# Monitoring credentials
# =========================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password
