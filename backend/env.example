APP_NAME=Forex Multi-Agent Platform
ENV=dev
API_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ORIGINS=http://localhost:5173

POSTGRES_USER=forex
POSTGRES_PASSWORD=forex
POSTGRES_DB=forex_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://forex:forex@postgres:5432/forex_platform
DB_POOL_SIZE=12
DB_MAX_OVERFLOW=24
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_IGNORE_RESULT=true
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=forex_long_term_memory
MEMORY_VECTOR_SIZE=64
ENABLE_PGVECTOR=false

OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_INPUT_COST_PER_1M_TOKENS=0
OLLAMA_OUTPUT_COST_PER_1M_TOKENS=0

METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=
METAAPI_REGION=new-york
METAAPI_BASE_URL=https://mt-client-api-v1.london.agiliumtrade.ai
METAAPI_MARKET_BASE_URL=https://mt-market-data-client-api-v1.london.agiliumtrade.ai
METAAPI_AUTH_HEADER=auth-token
ENABLE_METAAPI_REAL_TRADES_DASHBOARD=false
METAAPI_USE_SDK_FOR_MARKET_DATA=false
METAAPI_CACHE_ENABLED=true
METAAPI_CACHE_CONNECT_TIMEOUT_SECONDS=0.25
METAAPI_SDK_CONNECT_TIMEOUT_SECONDS=6
METAAPI_SDK_SYNC_TIMEOUT_SECONDS=6
METAAPI_SDK_REQUEST_TIMEOUT_SECONDS=8
METAAPI_SDK_CIRCUIT_BREAKER_SECONDS=20
METAAPI_ACCOUNT_INFO_CACHE_TTL_SECONDS=5
METAAPI_MARKET_CANDLES_CACHE_MIN_TTL_SECONDS=2
METAAPI_MARKET_CANDLES_CACHE_MAX_TTL_SECONDS=12
YFINANCE_CACHE_ENABLED=true
YFINANCE_CACHE_CONNECT_TIMEOUT_SECONDS=0.25
YFINANCE_SNAPSHOT_CACHE_MIN_TTL_SECONDS=2
YFINANCE_SNAPSHOT_CACHE_MAX_TTL_SECONDS=30
YFINANCE_NEWS_CACHE_TTL_SECONDS=120
YFINANCE_HISTORICAL_CACHE_TTL_SECONDS=900
YFINANCE_CACHE_FRAME_MAX_ROWS=5000

# Optional legacy aliases (if you already use them):
# API_TOKEN=
# ACCOUNT_ID=
# BASE_URL=https://mt-client-api-v1.london.agiliumtrade.ai
# BASE_MARKET_URL=https://mt-market-data-client-api-v1.london.agiliumtrade.ai

ALLOW_LIVE_TRADING=false
ENABLE_PAPER_EXECUTION=true
DEFAULT_FOREX_PAIRS=EURUSD.pro,GBPUSD.pro,USDJPY.pro,USDCHF.pro,AUDUSD.pro,USDCAD.pro,NZDUSD.pro,EURJPY.pro,GBPJPY.pro,EURGBP.pro
DEFAULT_CRYPTO_PAIRS=ADAUSD,AVAXUSD,BCHUSD,BNBUSD,BTCUSD,DOGEUSD,DOTUSD,ETHUSD,LINKUSD,LTCUSD,MATICUSD,SOLUSD,UNIUSD
DEFAULT_TIMEFRAMES=M5,M15,H1,H4,D1

PROMETHEUS_ENABLED=true
OPEN_TELEMETRY_ENABLED=false
WS_RUN_POLL_SECONDS=2
WS_TRADING_ORDERS_POLL_SECONDS=2
LOG_AGENT_STEPS=true
BACKTEST_AGENT_LOG_EVERY=25
BACKTEST_ENABLE_LLM=false
BACKTEST_LLM_EVERY=24
SCHEDULER_ENABLED=true
SCHEDULER_BATCH_SIZE=20
